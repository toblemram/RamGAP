# Environment Variables
# =======================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
DEBUG=true
HOST=0.0.0.0
PORT=5050

# --- Database ---
# Local development: leave empty to use SQLite (ramgap.db)
# Azure PostgreSQL Flexible Server:
#   DATABASE_URL=postgresql://adminuser:YourPassword@yourserver.postgres.database.azure.com:5432/ramgap?sslmode=require
DATABASE_URL=

# --- Plaxis ---
PLAXIS_HOST=localhost
PLAXIS_DEFAULT_PORT=10000

# --- OpenAI / AI Assistant ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-large

# --- Knowledge Base ---
KNOWLEDGE_DIR=activities/ai_assistant/knowledge/plaxis_knowledge
FAISS_IDX_FULL=faiss_full.index
FAISS_IDX_SHORT=faiss_short.index
DOC_IDS_FILE=doc_ids.json

# --- Azure Blob Storage ---
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER=project-files
AZURE_STORAGE_TEMP_CONTAINER=temp-uploads

# --- Bug Report (GitHub Issues) ---
# Generer token på: https://github.com/settings/tokens/new
# Velg "Fine-grained token" → Repository: toblemram/RamGAP → Permission: Issues = Read & Write
GITHUB_TOKEN=github_pat_...
