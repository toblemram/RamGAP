# Environment Variables
# =======================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
DEBUG=true
HOST=0.0.0.0
PORT=5050

# --- Database ---
# Leave empty to use local SQLite (ramgap.db)
DATABASE_URL=

# --- Plaxis ---
PLAXIS_HOST=localhost
PLAXIS_DEFAULT_PORT=10000

# --- OpenAI / AI Assistant ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-large

# --- Knowledge Base ---
KNOWLEDGE_DIR=activities/ai_assistant/knowledge/plaxis_knowledge
FAISS_IDX_FULL=faiss_full.index
FAISS_IDX_SHORT=faiss_short.index
DOC_IDS_FILE=doc_ids.json
